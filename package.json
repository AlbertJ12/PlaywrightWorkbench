  "scripts": {
    "test": "npx playwright test",
    "test:chromium": "npx playwright test --browser=chromium",
    "test:first": "npx playwright test --grep @first",
    "test:firefox": "npx playwright test --browser=firefox",
    "test:webkit": "npx playwright test --browser=webkit",
    "test:local": "BASE_URL=http://localhost:3000 npx playwright test",
    "test:report": "npx playwright test && npx playwright show-report",
    "test:ui": "npx playwright test --ui"
  },
